@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using OIL.Shared.Services

<MudThemeProvider Theme="_currentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="1" Style="background-color: white; color: black;">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.False" OnClick="ToggleDrawer">Menu</MudIconButton>
                <MudText Typo="Typo.h6" Class="ms-2">Field Maintenance Systems</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="Logout">Logout</MudButton>
            </MudAppBar>
            
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu />
            </MudDrawer>

            <MudMainContent>
                <div class="pa-4">
                    @Body
                </div>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @* This block renders for the Login Page *@
        <div class="d-flex align-center justify-center" style="height:100vh;">
            @Body
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    bool _drawerOpen = true;
    [Inject] private AuthService AuthService { get; set; }
    [Inject] private NavigationManager Nav { get; set; }

    private void Logout()
    {
        AuthService.Logout();
        Nav.NavigateTo("login");
    }

    private CancellationTokenSource? _cts;

    // Modified Toggle Method
    private async Task ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;

        if (_drawerOpen)
        {
            // Cancel any existing timer if user clicks quickly
            _cts?.Cancel();
            _cts = new CancellationTokenSource();

            try
            {
                await Task.Delay(5000, _cts.Token);
                _drawerOpen = false;
                StateHasChanged(); // Notify Blazor to re-render
            }
            catch (TaskCanceledException)
            {
                // Timer was reset because drawer was toggled again
            }
        }
    }

    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight() { Primary = "#D32F2F", AppbarBackground = "#D32F2F" }
    };
}