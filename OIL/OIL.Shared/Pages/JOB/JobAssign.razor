@page "/jobassign"
@using MudBlazor
@using Supabase
@using Supabase.Postgrest.Models
@using Supabase.Postgrest.Attributes
@using Newtonsoft.Json
@inject Supabase.Client SupabaseClient
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-10">
    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true"><b>OIL Resource Dispatch Mapper</b></MudText>

    @* --- SECTION 1: FORM --- *@
    <MudGrid Justify="Justify.Center" Class="align-center mt-4">
        <MudItem xs="12" md="3">
            <MudPaper Elevation="4" Class="pa-3" Style="border-top: 4px solid var(--mud-palette-primary);">
                <MudText Typo="Typo.subtitle2" Class="mb-1"><b>1. Driver / Vehicle</b></MudText>
                <MudSelect T="Driver" Label="Select Driver" Variant="Variant.Outlined" @bind-Value="_selectedDriver" Dense="true">
                    @foreach (var d in _dbDrivers)
                    {
                        <MudSelectItem T="Driver" Value="@d">@d.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-3" Style="border-top: 4px solid var(--mud-palette-info);">
                <MudText Typo="Typo.subtitle2" Class="mb-1"><b>2. Jobs Assigned</b></MudText>
                <MudSelect T="Job" Label="Select Jobs" MultiSelection="true"
                           @bind-SelectedValues="_selectedJobs"
                           Variant="Variant.Outlined" Dense="true">
                    @foreach (var j in _dbJobs)
                    {
                        <MudSelectItem T="Job" Value="@j">@j.JobName</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="3">
            <MudPaper Elevation="4" Class="pa-3" Style="border-top: 4px solid var(--mud-palette-secondary);">
                <MudText Typo="Typo.subtitle2" Class="mb-1"><b>3. Personnel</b></MudText>
                <MudSelect T="Engineer" Label="Select Team" MultiSelection="true"
                           @bind-SelectedValues="_selectedEngineers"
                           Variant="Variant.Outlined" Dense="true">
                    @foreach (var p in _dbEngineers)
                    {
                        <MudSelectItem T="Engineer" Value="@p">@p.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="1">
            <MudFab Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" OnClick="SaveAssignment" />
        </MudItem>
    </MudGrid>

    @* --- SECTION 2: TABLE --- *@
    <MudTable Items="@_assignments" Class="mt-8" Dense="true" Hover="true" Elevation="4">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Doc No</MudTh>
            <MudTh>Driver</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.PrintableDate</MudTd>
            <MudTd><b>@context.DocNumber</b></MudTd>
            <MudTd>@GetDriverName(context.DriverId)</MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Info" OnClick="@(() => OpenPrintCard(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteAssignment(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@* --- SECTION 3: JOB CARD PRINT --- *@
@if (_isPrintModalOpen)
{
    <div class="oil-print-overlay">
        <div id="print-area" class="oil-card">
            <div class="card-header">
                <div class="header-box"><b>OIL INDIA LIMITED</b><br /><small>Instrumentation Dept</small></div>
                <div class="header-box"><b>JOB CARD</b><br /><small>@_printItem.DocNumber</small></div>
                <div class="header-box text-right"><b>Date:</b><br />@_printItem.PrintableDate</div>
            </div>
            <div class="card-body">
                <div><b>Jobs:</b><br />@foreach(var id in _printItem.JobIds) {
                    <div>• @GetJobName(id)</div>
                }
            </div>
            <div><b>Team:</b> @string.Join(", ", _printItem.PersonnelIds.Select(GetEngineerName))</div>
            <div><b>Driver:</b> @GetDriverName(_printItem.DriverId)</div>
        </div>
        <div class="no-print mt-4 d-flex justify-center gap-2">
            <MudButton Variant="Variant.Outlined" OnClick="() => _isPrintModalOpen = false">Close</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="PrintNow">Print</MudButton>
        </div>
    </div>
</div>
}

<style>
    .oil-print-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        z-index: 9999;
        overflow-y: auto;
        padding: 20px;
    }

    .oil-card {
        width: 210mm;
        margin: auto;
        border: 2px solid black;
        padding: 15mm;
        color: black;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        border-bottom: 2px solid black;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .card-body div {
        margin-bottom: 15px;
        border: 1px solid #ccc;
        padding: 10px;
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        #print-area, #print-area * {
            visibility: visible;
        }

        #print-area {
            position: absolute;
            left: 0;
            top: 0;
        }

        .no-print {
            display: none !important;
        }
    }
</style>

@code {
    private bool _loading = true, _isPrintModalOpen;

    // TYPE FIX: MudBlazor MultiSelection binds best to IReadOnlyCollection for the EventCallback
    private Driver? _selectedDriver;
    private IReadOnlyCollection<Job> _selectedJobs { get; set; } = new List<Job>();
    private IReadOnlyCollection<Engineer> _selectedEngineers { get; set; } = new List<Engineer>();

    private List<Driver> _dbDrivers = new();
    private List<Job> _dbJobs = new();
    private List<Engineer> _dbEngineers = new();
    private List<Assignment> _assignments = new();
    private Assignment _printItem = new();

    // MODEL FIX: Inherit from BaseModel and add Table Attributes
    [Table("drivers")]
    public class Driver : BaseModel
    {
        [PrimaryKey("id")] public long Id { get; set; }
        [Column("full_name")] public string FullName { get; set; } = "";
    }

    [Table("jobs")]
    public class Job : BaseModel
    {
        [PrimaryKey("id")] public Guid Id { get; set; }
        [Column("job_name")] public string JobName { get; set; } = "";
    }

    [Table("employees_engineers")]
    public class Engineer : BaseModel
    {
        [PrimaryKey("id")] public long Id { get; set; }
        [Column("full_name")] public string FullName { get; set; } = "";
    }

    [Table("job_assignments")]
    public class Assignment : BaseModel
    {
        [PrimaryKey("id", false)] public Guid Id { get; set; }
        [Column("created_at")] public DateTime? CreatedAt { get; set; }
        [Column("driver_id")] public long? DriverId { get; set; }
        [Column("job_ids")] public List<Guid> JobIds { get; set; } = new();
        [Column("personnel_ids")] public List<long> PersonnelIds { get; set; } = new();
        [Column("doc_number")] public string DocNumber { get; set; } = "";
        public string PrintableDate => CreatedAt?.ToLocalTime().ToString("dd/MM/yy HH:mm") ?? "";
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            _dbDrivers = (await SupabaseClient.From<Driver>().Get()).Models;
            _dbJobs = (await SupabaseClient.From<Job>().Get()).Models;
            _dbEngineers = (await SupabaseClient.From<Engineer>().Get()).Models;
            _assignments = (await SupabaseClient.From<Assignment>().Order("created_at", Supabase.Postgrest.Constants.Ordering.Descending).Get()).Models;
        }
        catch { Snackbar.Add("Error loading data", Severity.Error); }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task SaveAssignment()
    {
        if (_selectedDriver == null || !_selectedJobs.Any()) return;

        try
        {
            var item = new Assignment
            {
                Id = Guid.NewGuid(),
                CreatedAt = DateTime.UtcNow,
                DriverId = _selectedDriver.Id,
                JobIds = _selectedJobs.Select(x => x.Id).ToList(),
                PersonnelIds = _selectedEngineers.Select(x => x.Id).ToList(),
                DocNumber = $"OIL-{DateTime.Now:ddMMyy-HHmm}"
            };

            await SupabaseClient.From<Assignment>().Insert(item);
            await LoadData();

            // Clear selections
            _selectedDriver = null;
            _selectedJobs = new List<Job>();
            _selectedEngineers = new List<Engineer>();

            Snackbar.Add("Job Card Created", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private void OpenPrintCard(Assignment item) { _printItem = item; _isPrintModalOpen = true; }
    private async Task DeleteAssignment(Guid id) { await SupabaseClient.From<Assignment>().Where(x => x.Id == id).Delete(); await LoadData(); }
    private async Task PrintNow() => await JS.InvokeVoidAsync("window.print");
    private string GetDriverName(long? id) => _dbDrivers.FirstOrDefault(x => x.Id == id)?.FullName ?? "N/A";
    private string GetJobName(Guid id) => _dbJobs.FirstOrDefault(x => x.Id == id)?.JobName ?? "N/A";
    private string GetEngineerName(long id) => _dbEngineers.FirstOrDefault(x => x.Id == id)?.FullName ?? "N/A";
}