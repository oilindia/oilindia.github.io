    private async Task LocateMarker(Marker m)
    {
        if (!m.CoordX.HasValue || !m.CoordY.HasValue) return;
        _zoomLevel = 1.2;
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("scrollToMarker", "pid-map-container", m.CoordX.Value, m.CoordY.Value);
    }

