    private void OpenEdit(Marker m) { _selectedMarker = m; _drawerOpen = true; }
    private string GetZoomStyle() => $"position: relative; display: inline-block; width: {(_zoomLevel * 100)}%; transition: width 0.2s ease; transform-origin: top left;";
    public class Dimensions { public double Width { get; set; } public double Height { get; set; } }
