@* ChatBotComponent.razor *@
@page "/chatbot"

@using MudBlazor
@using OIL.Shared.Services

@inject GeminiService AiService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudPaper Elevation="4" Class="pa-4"
          Style="height: 550px; display: flex; flex-direction: column; background: #f4f4f9;">

    <!-- HEADER -->
    <MudText Typo="Typo.h6" Class="mb-2">
        🤖 AI Assistant
    </MudText>

    <!-- CHAT AREA -->
    <div id="chat-container"
         style="flex-grow: 1; overflow-y: auto; padding-right: 10px;">

        @foreach (var msg in Messages)
        {
            <div style="display:flex; justify-content:@(msg.Role == "user" ? "flex-end" : "flex-start")">

                <MudPaper Class="pa-2 mb-2"
                          Style="@GetBubbleStyle(msg)">
                    @msg.Text
                </MudPaper>

            </div>
        }

        @if (IsLoading)
        {
            <MudProgressLinear Indeterminate="true"
                               Color="Color.Primary"
                               Class="mb-2" />
        }

    </div>

    <!-- TICKET BUTTON -->
    @if (ShowTicketButton)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   FullWidth="true"
                   Class="mb-2"
                   OnClick="LogTicket"
                   StartIcon="@Icons.Material.Filled.Assignment">

            Log Maintenance Ticket
        </MudButton>
    }

    <!-- INPUT -->
    <MudTextField @bind-Value="UserInput"
                  Placeholder="Type message..."
                  Variant="Variant.Outlined"
                  Class="mt-2"
                  Immediate="true"
                  OnKeyDown="HandleKeyDown"
                  Adornment="Adornment.End"
                  AdornmentIcon="@Icons.Material.Filled.Send"
                  OnAdornmentClick="SendMessage" />

</MudPaper>

@code {

    // ✅ USE SERVICE MODEL ONLY (NO DUPLICATE CLASS)
    private List<ChatMessage> Messages = new();

    private string UserInput = "";
    private bool IsLoading = false;
    private bool ShowTicketButton = false;

    // ✅ SEND MESSAGE
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(UserInput))
            return;

        // Add user message
        var userMsg = new ChatMessage("user", UserInput);

        


        //userMsg.Text = userMsg.Text + systemPrompt;

        Messages.Add(userMsg);

        IsLoading = true;
        StateHasChanged();

        try
        {
            // Call your Supabase → Gemini API
            var response = await AiService.Chat(Messages, "", new string[] { });

            if (!string.IsNullOrWhiteSpace(response))
            {
                if (response.Contains("SIGNAL_TICKET_LOG"))
                {
                    ShowTicketButton = true;
                    response = response.Replace(
                        "SIGNAL_TICKET_LOG",
                        "⚠ I recommend logging a maintenance ticket.");
                }
                if (response.Contains("You exceeded your current quota, please check your plan and billing details"))
                {
                    ShowTicketButton = true;
                    Messages.Add(new ChatMessage("model", "AI is taking a breather. Try again in a min. or log a ticket directly"));
 
                }

                // Add AI response
                Messages.Add(new ChatMessage("model", response));
            }
            else
            {
                Messages.Add(new ChatMessage("model", "No response from AI."));
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"API Error: {ex.Message}", Severity.Error);
            Messages.Add(new ChatMessage("model", "⚠ Error getting response."));
        }

        UserInput = "";
        IsLoading = false;

        await ScrollToBottom();
        StateHasChanged();
    }

    // ✅ ENTER KEY SUPPORT
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    // ✅ AUTO SCROLL
    private async Task ScrollToBottom()
    {
        await JSRuntime.InvokeVoidAsync("eval",
            @"var el = document.getElementById('chat-container');
              if(el) el.scrollTop = el.scrollHeight;");
    }

    // ✅ CHAT BUBBLE STYLE FIX (NO INLINE EXPRESSION ERROR)
    private string GetBubbleStyle(ChatMessage msg)
    {
        if (msg.Role == "user")
        {
            return "max-width:70%; background:#1976d2; color:white; border-radius:12px;";
        }
        else
        {
            return "max-width:70%; background:#e0e0e0; color:black; border-radius:12px;";
        }
    }

    // ✅ NAVIGATION
    private void LogTicket()
    {
        NavManager.NavigateTo("/reportnewjob");
    }
}