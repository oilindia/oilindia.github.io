@page "/chatbot"
@using MudBlazor
@using OIL.Shared.Services
@inject GeminiService AiService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models

<MudPaper Elevation="4" Class="pa-4" Style="height: 600px; display:flex; flex-direction:column; background:#f4f4f9; border-radius: 12px;">
    <MudText Typo="Typo.h6" Class="mb-2">🤖 OCS Maintenance Assistant</MudText>

    <div id="chat-container" style="flex-grow:1; overflow-y:auto; padding:10px; background: white; border-radius: 8px;">
        @foreach (var msg in Messages)
        {
            <div style="display:flex; justify-content:@(msg.Role == "user" ? "flex-end" : "flex-start")">
                <MudPaper Class="pa-3 mb-3" Style="@GetBubbleStyle(msg)" Elevation="1">
                    <MudText Typo="Typo.body1">@msg.Text</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.6">@msg.Time.ToLocalTime().ToString("HH:mm")</MudText>
                </MudPaper>
            </div>
        }
        @if (IsLoading)
        {
            <MudProgressLinear Color="Color.Info" Indeterminate="true" Class="my-2" />
        }
    </div>

    @if (ShowTicketButton)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error" Class="my-2" OnClick="LogTicket" StartIcon="@Icons.Material.Filled.Assignment">
            Log Maintenance Ticket for OCS-4
        </MudButton>
    }

    <MudTextField @bind-Value="UserInput" Placeholder="e.g. Heater burner not igniting..." Variant="Variant.Outlined"
                  OnKeyDown="HandleKeyDown" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Send"
                  OnAdornmentClick="SendMessage" Class="mt-4" AutoFocus="true" />
</MudPaper>

@code {

    [Table("chat_sessions")]
    public class ChatSession : BaseModel
    {
        [PrimaryKey("id")]
        public string Id { get; set; }

        [Column("history")]
        public string History { get; set; }

        [Column("updated_at")]
        public DateTime UpdatedAt { get; set; }
    }

    private List<ChatMessage> Messages = new();
    private string UserInput = "";
    private bool IsLoading;
    private bool ShowTicketButton;



    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(UserInput)) return;

        var text = UserInput.Trim();
        Messages.Add(new ChatMessage("user", text));
        UserInput = "";
        IsLoading = true;
        StateHasChanged();
        await Scroll();

        var response2 = await AiService.Chat(Messages);

        var response = await AiService.ProcessMaintenanceChat(Messages);

        if (response.Contains("SIGNAL_TICKET_LOG"))
        {
            ShowTicketButton = true;
            response = response.Replace("SIGNAL_TICKET_LOG", "⚠ Recommended: Log a formal ticket.");
        }

        Messages.Add(new ChatMessage("model", response));
        IsLoading = false;
        await Scroll();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await SendMessage(); }

    private async Task Scroll() => await JSRuntime.InvokeVoidAsync("eval", "var el=document.getElementById('chat-container'); if(el) el.scrollTop=el.scrollHeight;");

    private string GetBubbleStyle(ChatMessage msg) => msg.Role == "user"
        ? "max-width:80%; background:#1976d2; color:white; border-radius:15px 15px 0px 15px;"
        : "max-width:80%; background:#e0e0e0; color:black; border-radius:15px 15px 15px 0px;";

    private void LogTicket() => NavManager.NavigateTo("/reportnewjob");
}