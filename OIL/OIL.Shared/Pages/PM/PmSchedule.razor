@page "/pmschedule"
@using MudBlazor

<MudText Typo="Typo.h4" Class="mb-4">Master PM Schedule</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="4" Class="pa-4">
            <MudText Typo="Typo.h6">Add New Instrument</MudText>
            <MudTextField @bind-Value="newTask.TagId" Label="Tag ID" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
            <MudTextField @bind-Value="newTask.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
            <MudSelect @bind-Value="newTask.Frequency" T="string" Label="Frequency" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2">
                <MudSelectItem Value="@("Monthly")" />
                <MudSelectItem Value="@("Quarterly")" />
                <MudSelectItem Value="@("Annually")" />
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4" OnClick="AddInstrument">Add to Master List</MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudTable Items="@Instruments" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="4">
            <HeaderContent>
                <MudTh>Tag ID</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Frequency</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tag ID">@context.TagId</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Frequency">@context.Frequency</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private List<MaintenanceTask> Instruments = new();
    private MaintenanceTask newTask = new();

    private void AddInstrument()
    {
        if (!string.IsNullOrWhiteSpace(newTask.TagId))
        {
            Instruments.Add(newTask);
            newTask = new();
        }
    }

    private void Delete(MaintenanceTask item) => Instruments.Remove(item);
}
@code {

    public class MaintenanceTask
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string TagId { get; set; }
        public string Description { get; set; }
        public string Frequency { get; set; } = "Monthly";
        public DateTime NextDueDate { get; set; } = DateTime.Now;
        public string Status { get; set; } = "Pending";
        public string TechnicianNotes { get; set; }
    }


    private List<MaintenanceTask> ScheduleList = new();
    private MaintenanceTask currentTask = new();

    void SaveTask()
    {
        if (!ScheduleList.Any(t => t.Id == currentTask.Id))
            ScheduleList.Add(currentTask);
        currentTask = new();
    }

    void EditTask(MaintenanceTask task) => currentTask = task;
    void DeleteTask(string id) => ScheduleList.RemoveAll(t => t.Id == id);
}
