    //         // Save Reference
    //         _uploadModel.id = Guid.NewGuid();
    //         _uploadModel.FileName = _selectedFile.Name;
    //         _uploadModel.StoragePath = destination;
            
    //         await SupabaseClient.From<TechnicalDoc>().Insert(_uploadModel);

    //         Snackbar.Add("Document Stored in technical-docs", Severity.Success);
    //         _selectedFile = null;
    //         await LoadData();
    //     }
    //     catch (Exception ex) { Snackbar.Add($"Storage Error: {ex.Message}", Severity.Error); }
    //     finally { _isUploading = false; }
    // }

    private async Task ViewDoc(TechnicalDoc doc) {
        _viewingUrl = doc.GetPublicUrl();
        _viewingDocName = doc.FileName;
        _viewerOpen = true;
    }

    private async Task DownloadDoc(TechnicalDoc doc) => await JS.InvokeVoidAsync("open", doc.GetPublicUrl(), "_blank");

    private async Task ConfirmDelete(TechnicalDoc doc) {
        bool? result = await DialogService.ShowMessageBoxAsync("Delete", $"Permanently remove {doc.FileName}?", yesText:"Delete", cancelText:"Cancel");
        if (result == true) {
            await SupabaseClient.Storage.From("technical-docs").Remove(new List<string> { doc.StoragePath });
            await SupabaseClient.From<TechnicalDoc>().Where(x => x.id == doc.id).Delete();
            await LoadData();
            Snackbar.Add("Removed from Cloud Storage", Severity.Warning);
        }
    }
}